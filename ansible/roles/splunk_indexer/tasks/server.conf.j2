{# =========================================================================== #}
{# server.conf.j2 — splunk_indexer                                           #}
{#                                                                            #}
{# Owns ONLY: [clustering] peer stanza + [replication_port]                  #}
{# The CM URI is derived at runtime from the cluster_manager inventory group. #}
{# =========================================================================== #}

[clustering]
mode = peer
master_uri = {{ splunk_cm_uri }}
pass4SymmKey = {{ splunk_cluster_pass4symmkey }}

[replication_port://{{ splunk_replication_port }}]
