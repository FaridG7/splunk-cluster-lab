{# =========================================================================== #}
{# inputs.conf.j2 — splunk_indexer                                           #}
{#                                                                            #}
{# Opens the TCP receiving port that Universal Forwarders send data to.      #}
{# The Deployment Server pushes an outputs.conf app to forwarders that       #}
{# points at this port on all indexer peers (round-robin by default).        #}
{# =========================================================================== #}

[splunktcp://{{ splunk_receiving_port }}]
connection_host = dns        # resolve sender hostname via reverse DNS for metadata
