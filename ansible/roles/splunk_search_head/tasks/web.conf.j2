{# =========================================================================== #}
{# web.conf.j2 — splunk_search_head                                          #}
{#                                                                            #}
{# Controls the Splunk Web interface on the Search Head.                     #}
{# TLS is toggled via splunk_enable_tls (false in lab).                      #}
{# =========================================================================== #}

[settings]
httpport = {{ splunk_web_port }}
enableSplunkWebSSL = {{ splunk_enable_tls | lower }}
